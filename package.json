{
  "name": "sr-digad",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "pnpm": {
    "overrides": {
      "glob": "^8.1.0"
    }
  },
  "scripts": {
    "dev": "vite",
    "ts-lint": "tsc --noEmit",
    "ts-lint:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "prepreview": "node -e \"const fs=require('fs');if(fs.existsSync('preview')){fs.rmSync('preview',{recursive:true,force:true});}fs.mkdirSync('preview');\"",
    "preview": "concurrently pnpm:preview:*",
    "preview:300x250": "tsc && vite build",
    "package": "pnpm run preview && node lib/scripts/package",
    "postpreview": "node --no-warnings=ExperimentalWarning lib/scripts/postpreview",
    "prettier:fix": "prettier --write \"{,!(build|node_modules|preview|templates)/**}/*.{js,ts,css,scss,html}\"",
    "preview:728x90": "tsc && vite build"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "fast-glob": "^3.3.3",
    "html2canvas-pro": "^2.0.2",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-handlebars": "^2.0.0",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-imagemin": "^0.6.1",
    "vite-plugin-restart": "^2.0.0",
    "vite-plugin-singlefile": "^2.3.0",
    "vite-plugin-spritesmith": "github:fishpondstudio/vite-plugin-spritesmith#a933c5fbda1b7288100781618078cc322071f1d4",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "dependencies": {
    "gsap": "file:lib/gsap/gsap-bonus-3.12.4.tgz",
    "js-yaml": "^4.1.1"
  }
}
